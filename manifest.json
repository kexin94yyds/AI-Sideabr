{
  "manifest_version": 3,
  "name": " ",
  "version": "0.0.1",
  "description": "A Chrome extension that brings ChatGPT, Perplexity, and Gemini to your browser side panel",
  "permissions": [
    "sidePanel",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "tabs",
    "activeTab",
    "storage",
    "cookies",
    "identity",
    "scripting",
    "contextMenus"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "js/plugins/exporter-logic.js",
        "js/plugins/storage-manager.js",
        "content-scripts/watermark-assets/bg_48.png",
        "content-scripts/watermark-assets/bg_96.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "action": {
    "default_title": ""
  },
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://*.perplexity.ai/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*",
    "https://*.genspark.ai/*",
    "https://www.genspark.ai/*",
    "https://genspark.ai/*",
    "https://*.tongyi.com/*",
    "https://www.tongyi.com/*",
    "https://tongyi.com/*",
    "https://*.doubao.com/*",
    "https://www.doubao.com/*",
    "https://doubao.com/*",
    "https://gemini.google.com/*",
    "https://aistudio.google.com/*",
    "https://accounts.google.com/*",
    "https://www.google.com/*",
    "https://claude.ai/*",
    "https://chat.deepseek.com/*",
    "https://*.deepseek.com/*",
    "https://deepseek.com/*",
    "https://notebooklm.google.com/*",
    "https://ima.qq.com/*",
    "https://*.ptlogin2.qq.com/*",
    "https://ssl.ptlogin2.qq.com/*",
    "https://xui.ptlogin2.qq.com/*",
    "https://attention-span-tracker.netlify.app/*",
    "https://grok.com/*",
    "https://mubu.com/*",
    "https://*.mubu.com/*",
    "https://excalidraw.com/*",
    "https://tobooks.netlify.app/*",
    "https://kimi.moonshot.cn/*",
    "https://*.moonshot.cn/*",
    "https://v0.dev/*",
    "https://copilot.microsoft.com/*",
    "https://*.microsoft.com/*",
    "https://github.com/*",
    "https://*.github.com/*",
    "https://chat.mistral.ai/*",
    "https://*.mistral.ai/*",
    "https://coral.cohere.com/*",
    "https://*.cohere.com/*",
    "https://huggingface.co/*",
    "https://*.huggingface.co/*",
    "https://www.meta.ai/*",
    "https://meta.ai/*",
    "https://chatglm.cn/*",
    "https://*.chatglm.cn/*",
    "https://hailuoai.com/*",
    "https://*.hailuoai.com/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://*.perplexity.ai/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://*.genspark.ai/*",
        "https://www.genspark.ai/*",
        "https://genspark.ai/*",
        "https://*.tongyi.com/*",
        "https://www.tongyi.com/*",
        "https://tongyi.com/*",
        "https://*.doubao.com/*",
        "https://www.doubao.com/*",
        "https://doubao.com/*",
        "https://gemini.google.com/*",
        "https://aistudio.google.com/*",
        "https://accounts.google.com/*",
        "https://www.google.com/*",
        "https://claude.ai/*",
        "https://chat.deepseek.com/*",
        "https://*.deepseek.com/*",
        "https://deepseek.com/*",
        "https://notebooklm.google.com/*",
        "https://ima.qq.com/*",
        "https://*.ptlogin2.qq.com/*",
        "https://ssl.ptlogin2.qq.com/*",
        "https://xui.ptlogin2.qq.com/*",
        "https://attention-span-tracker.netlify.app/*",
        "https://grok.com/*",
        "https://mubu.com/*",
        "https://*.mubu.com/*",
        "https://excalidraw.com/*",
        "https://tobooks.netlify.app/*",
        "https://kimi.moonshot.cn/*",
        "https://*.moonshot.cn/*",
        "https://v0.dev/*",
        "https://copilot.microsoft.com/*",
        "https://*.microsoft.com/*",
        "https://github.com/*",
        "https://*.github.com/*",
        "https://chat.mistral.ai/*",
        "https://*.mistral.ai/*",
        "https://coral.cohere.com/*",
        "https://*.cohere.com/*",
        "https://huggingface.co/*",
        "https://*.huggingface.co/*",
        "https://www.meta.ai/*",
        "https://meta.ai/*",
        "https://chatglm.cn/*",
        "https://*.chatglm.cn/*",
        "https://hailuoai.com/*",
        "https://*.hailuoai.com/*"
      ],
      "all_frames": true,
      "run_at": "document_end",
      "js": [
        "content-scripts/url-sync.js",
        "js/plugins/exporter-logic.js",
        "js/plugins/storage-manager.js"
      ]
    },
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "all_frames": true,
      "run_at": "document_idle",
      "js": [
        "content-scripts/gemini-common.js",
        "content-scripts/gemini-folder.js",
        "content-scripts/gemini-folder-layout.js",
        "content-scripts/gemini-sidebar-width.js",
        "content-scripts/gemini-sidebar-auto-hide.js",
        "content-scripts/gemini-chat-width.js",
        "content-scripts/gemini-edit-input-width.js",
        "content-scripts/gemini-input-resize.js",
        "content-scripts/gemini-footer-hide.js",
        "content-scripts/gemini-timeline.js",
        "content-scripts/gemini-input-collapse.js",
        "content-scripts/gemini-snow-effect.js",
        "content-scripts/gemini-voyager-settings-panel.js"
      ]
    },
    {
      "matches": [
        "https://notebooklm.google.com/*"
      ],
      "all_frames": true,
      "run_at": "document_idle",
      "js": [
        "content-scripts/universal-input-collapse.js",
        "content-scripts/notebooklm-sidebar-hide.js"
      ]
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://chat.deepseek.com/*",
        "https://kimi.moonshot.cn/*",
        "https://*.tongyi.com/*",
        "https://*.doubao.com/*",
        "https://*.perplexity.ai/*",
        "https://copilot.microsoft.com/*",
        "https://grok.com/*"
      ],
      "all_frames": true,
      "run_at": "document_idle",
      "js": [
        "content-scripts/universal-input-collapse.js"
      ]
    },
    {
      "matches": ["<all_urls>"],
      "all_frames": false,
      "run_at": "document_end",
      "js": ["content-scripts/parallel-panel.js"]
    }
  ],

  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "bypass_headers",
        "enabled": true,
        "path": "rules/bypass-headers.json"
      }
    ]
  },
  "commands": {
    "aisb-send-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Send selected text to AI sidebar"
    },
    "aisb-capture-screenshot": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Capture current tab screenshot to side panel"
    },
    "aisb-export-chat": {
      "suggested_key": {
        "default": "Ctrl+S",
        "mac": "Command+S"
      },
      "description": "Export current chat"
    },
    "aisb-open-parallel-left": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Open left floating parallel AI panel"
    }
  }
}
