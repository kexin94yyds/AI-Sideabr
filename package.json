{
  "name": "chatgpt-bar-chrome-extension",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc",
    "lint": "eslint . --ext js,ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "native-host": "node scripts/native-mirror-host.cjs",
    "native-host:install": "node scripts/install-native-host.cjs",
    "sync-server": "node scripts/sync-server.cjs",
    "sync": "node scripts/sync-server.cjs",
    "package:webstore": "bash scripts/build-webstore-package.sh",
    "video:dev": "remotion studio remotion/index.ts",
    "video:render": "remotion render remotion/index.ts AiSidebarIntro out/ai-sidebar-intro.mp4"
  },
  "dependencies": {
    "@remotion/cli": "4.0.452",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remotion": "4.0.452"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.247",
    "@types/react": "^18.2.21",
    "@types/react-dom": "^18.2.8",
    "@typescript-eslint/eslint-plugin": "^6.7.3",
    "@typescript-eslint/parser": "^6.7.3",
    "@vitejs/plugin-react": "^4.2.0",
    "eslint": "^8.52.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "typescript": "^5.3.0",
    "vite": "^4.5.0"
  }
}
